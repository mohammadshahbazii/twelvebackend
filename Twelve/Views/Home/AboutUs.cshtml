                <h2 class="text-darkblue text-center fw-bold fs-3 font-ExtraBold">
                    @Model.ThirdTitle
                </h2>
                @await Component.InvokeAsync("AboutUsSight")
            </div>
            <br />
            <div data-aos="fade-up" data-aos-duration="1800">
