@model DataLayer.AboutUsContent
@section NavbarJs {
    <script src="/Assest/js/Scrolled-WhiteNav.js"></script>
}
@section Navbar{
    <partial name="_WhiteNavbar"></partial>
}

<!--Content-->
<article class="position-relative">
    <div class="container p-lg-5 p-3">
        <!-- Article Content -->
        <!-- Story -->
        <div data-aos="fade-up"
             data-aos-duration="1800"
             class="section--first bg-silver px-lg-5 pt-lg-5 pb-0 story-box radius-20 mb-5">
            <div class="row pt-5">
                <div class="col-lg-6 col-md-12 p-5">
                    <p class="text-lightpurple fw-bold mb-4">
                        @Model.SubTitle
                    </p>
                    <h2 class="text-darkblue fw-bold fs-2 font-ExtraBold mb-4">
                        @Model.Title
                    </h2>
                    <p class="text-pencil lh-lg">@Model.Description</p>
                </div>
                <div class="col-lg-6 col-md-12 pt-5">
                    <div class="position-relative text-center">
                        <img src="/Assest/img/SVG/Main/green-circle.svg"
                             style="padding-top: 0"
                             alt="دوازده"
                             class="green-list" />
                        <img src="/Images/Site/@Model.ImageName"
                             alt="دوازده"
                             class="w-md-100 h-100" />
                    </div>
                </div>
            </div>
        </div>
        <!-- Story -->
        <!-- Content -->
        <div data-aos="fade-up"
             data-aos-duration="1800"
             class="section--last my-5">
            <p class="text-green2 fw-bold my-2 mb-4">
                @Model.SecondSubTitle
            </p>
            <h1 class="text-darkblue fw-bold fs-2 font-ExtraBold">
                @Model.SecondTitle
            </h1>
            <p class="text-pencil text-justify my-4">@Model.SecondDescription</p>

            @await Component.InvokeAsync("AboutUsSlider")

        </div>
        <br />
        <!-- Content -->
        <!-- Article Content -->
    </div>
    <div class="bg-silver p-lg-5 position-relative">
