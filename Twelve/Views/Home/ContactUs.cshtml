@model List<ViewModels.SocialMediaItemViewModel>
@section NavbarJs {
    <script src="/Assest/js/Scrolled-WhiteNav.js"></script>
}
@section Navbar{
    <partial name="_WhiteNavbar"></partial>
}

 <!--Content-->
<article class="position-relative">
    <div class="bg-silver p-lg-5 position-relative">
        <div class="container p-5">
            <!-- Article Content -->
            <div data-aos="fade-up" data-aos-duration="1800" class="my-5">
                @await Component.InvokeAsync("ContactUsFirstDescription")
                @await Component.InvokeAsync("CallInfo")

            </div>
            <br />
            <div data-aos="fade-up" data-aos-duration="1800" class="my-4">
                <div class="contact-social row">
                    <div class="col-lg-6 col-md-12">
                        <h2 class="text-darkblue fw-bold font-ExtraBold fs-4 mb-4">
                            شبکه های اجتماعی به آدرس
                        </h2>
                    </div>
                    <div class="col-lg-6 col-md-12">
                        <div class="text-end">
                            @foreach (var item in Model)
                            {
                                <a href="@item.Link"
                                   target="_blank"
                                   title="@item.Title"
                                   class="fs-6 @item.ClassName text-darkblue">
                                    @Html.Raw(item.ImageName)
                                </a>
                            }
                            
                        </div>
                    </div>
                </div>
            </div>
            <br />
            <div data-aos="fade-up" data-aos-duration="1800" class="my-5">
                @await Component.InvokeAsync("ContactUsSecondDescription")
            </div>
