            <!-- Article Content -->
        </div>
    </div>
    <div class="container p-5 position-relative">
        <!-- Article Content -->
        <!--Photos-->
        <div class="contacts-photo mb-5 container mx-auto">
            @await Component.InvokeAsync("ContactsSlider")
        </div>
        <!--Photos-->
        <!--ContactUs-->
        <div data-aos="fade-up" data-aos-duration="1800" class="mt-20 mb-5">
            <h2 class="text-darkblue fw-bold fs-3 font-ExtraBold">
                ما اینجا هستیم برای پاسخگویی به شما
            </h2>
            <!--<p class="text-green2 fw-bold my-4">
              این یک نگهدارنده متن برای توضیحات بیشتر این عنوان
            </p>-->
