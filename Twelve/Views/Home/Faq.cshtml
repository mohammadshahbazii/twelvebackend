@section NavbarJs {
    <script src="/Assest/js/Scrolled-WhiteNav.js"></script>
}
@section Navbar{
    <partial name="_WhiteNavbar"></partial>
}
@section SeoTags {
    @await Component.InvokeAsync("MainSeoTags")

}

<!--Content-->
<article class="position-relative">
    @await Component.InvokeAsync("FaqsPage")

    <div class="bg-silver p-lg-5 py-5 position-relative">
        <div class="container">
            <!-- Article Content -->
            <!-- testimonial -->
            @await Component.InvokeAsync("IndexFeedBacks")
            <!-- testimonial -->
            <br />
            <div data-aos="fade-up" data-aos-duration="1800" class="my-5">
                <div class="bg-silver4 radius-20 p-lg-5 py-5">
                    <div class="m-lg-5">
                        <h3 class="text-darkblue fs-3 text-center fw-bold font-ExtraBold">
                            ارسال سوالات، پیشنهادات و انتقادات شما
                        </h3>
                        <p class="text-green2 text-center fw-bold mb-5">
                            اگر در بخش سوالات متدوال، پاسخ سوال خود را پیدا نکردید، در قسمت پشتیبانی سایت، پیام ارسال کنید
                        </p>
                        <!--Contact Form-->
                        @await Component.InvokeAsync("ContactsForm")

                        <!--Contact Form-->
                    </div>
                </div>
            </div>
            <br />
            <!-- Content -->
            <!-- Article Content -->
        </div>
    </div>
</article>

<!--Content-->