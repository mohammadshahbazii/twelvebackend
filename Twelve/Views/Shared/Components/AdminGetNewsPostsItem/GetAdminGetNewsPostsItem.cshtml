@model ViewModels.AdminBlogPageDataViewModel

@if (Model.Posts.Any())
{
    <div class="card-body table-responsive p-0">
        <table class="table table-bordered table-hover">
            <tbody>
                <tr>
                    <th>عنوان</th>
                    <th>ویژگی های مربوطه</th>
                    <th>تاریخ انتشار</th>
                    <th>بازدید</th>
                    <th>*</th>
                </tr>
                @foreach (var item in Model.Posts)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>
                            @item.GroupName
                        </td>
                        <td>@item.CreateDate</td>
                        <td>@item.View</td>
                        <td>
                            <a href="/Admin/News/Update/@item.BlogID" class="btn btn-outline-warning rounded mx-1" title="ویرایش">
                                <span class="fa fa-edit"></span>
                            </a>
                            <a href="/Admin/News/Delete/@item.BlogID" class="btn btn-outline-danger rounded mx-1" title="حذف">
                                <span class="fa fa-trash"></span>
                            </a>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
    <div class="card-footer clearfix">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination pagination-sm m-0 justify-content-center ">
                @if (Model.Pagination.PageID == 1)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID - 1))">«</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID - 1))">«</a></li>

                }
                @foreach (var item in Model.Pagination.PageNumbers)
                {
                    if (item == Model.Pagination.PageID)
                    {
                        <li class="page-item active"><a class="page-link" onclick="GetBlogs(@(item))">@item</a></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" onclick="GetBlogs(@(item))">@item</a></li>
                    }
                }

                @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID + 1))">»</a></li>

                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID + 1))">»</a></li>

                }
            </ul>


        }
    </div>
}