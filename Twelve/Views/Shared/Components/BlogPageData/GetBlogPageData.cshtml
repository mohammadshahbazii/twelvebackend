@model ViewModels.BlogPagesDataViewModel

<div class="row">
    <div class="col-lg-12 col-md-12">
        <div class="d-none d-lg-block d-xl-block d-xxl-block">
            <div class="mb-5 bg-silver border-bottom p-5 px-1 radius-20">
                <div>
                    <div class="mt-2">
                        <div class="blog-filter-row">
                            <div class="blog-filter-title">
                                <p class="text-darkblue pt-2 font-ExtraBold fw-bold">
                                    دسته بندی مطالب بلاگ<img src="Assest/img/list-title-icon.png"
                                                             width="24"
                                                             height="24"
                                                             class="mx-2" />
                                </p>
                            </div>
                            <div class="blog-filter-search">
                                <form role="search">
                                    <div class="input-group mb-3">
                                        <input type="text"
                                            name="q"
                                            value="@ViewBag.q"
                                               id="BlogSearch"
                                               class="form-control fs-6 navbar-search bg-light border border-0"
                                               placeholder="جستجو" />
                                        <a onclick="SearchBlogs()" class="input-group-text bg-light navbar-search-icon border border-0">
                                            <img src="Assest/img/SVG/Main/search-normal.svg" />
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="blog-filter-items">
                            <ul class="nav nav-pills nav-fill">
                                @foreach (var item in Model.Groups)
                                {
                                    if (item == Model.Groups[0])
                                    {
                                        <li class="nav-item faqs-tab-item">
                                            <a class="nav-link faqs-tab text-pencil active"
                                               data-bs-toggle="pill"
                                               href="#g_@(item.GroupID)">@item.GroupName</a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="nav-item faqs-tab-item">
                                            <a class="nav-link faqs-tab text-pencil "
                                               data-bs-toggle="pill"
                                               href="#g_@(item.GroupID)">@item.GroupName</a>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-lg-none d-xl-none d-xxl-none d-md-block d-sm-block">
            <div class="bg-white radius-20">
                <div class="blog-filter-row mt-5">
                    <div class="blog-filter-rightSide">
                        <p class="text-darkblue fs-12 fw-bold">
                            دسته بندی مطالب بلاگ<img src="/Assest/img/list-title-icon.png"
                                                     width="15"
                                                     height="15"
                                                     class="mx-2" />
                        </p>
                    </div>
                    <div class="blog-filter-leftSide">
                        <div class="dropdown ms-0">
                            <button class="bg-white fs-12 border-0 text-darkblue fw-bold dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                دسته بندی
                            </button>

                            <ul class="dropdown-menu nav-pills" role="tablist">
                                @foreach (var item in Model.Groups)
                                {
                                    if (item == Model.Groups[0])
                                    {
                                        <li class="nav-item faqs-tab-item m-3 text-center">
                                            <a class="dropdown-item nav-link faqs-tab text-pencil active"
                                               data-bs-toggle="pill"
                                               href="#g_@(item.GroupID)">@item.GroupName</a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li class="nav-item faqs-tab-item m-3 text-center">
                                            <a class="dropdown-item nav-link faqs-tab text-pencil"
                                               data-bs-toggle="pill"
                                               href="#g_@(item.GroupID)">@item.GroupName</a>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="my-2">
                <form role="search blog-faq-search">
                    <div class="input-group mb-3">
                        <input type="text"
                               value="@ViewBag.q"
                               id="BlogSearchs"
                               class="form-control fs-12 navbar-search bg-white border border-0"
                               placeholder="جستجو" />
                        <a onclick="SearchsBlogs()" class="input-group-text bg-white navbar-search-icon border border-0">
                            <img src="/Assest/img/SVG/Main/search-normal.svg" />
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<br />
