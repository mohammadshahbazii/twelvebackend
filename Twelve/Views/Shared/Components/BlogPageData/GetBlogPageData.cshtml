<script>
    function GetNews(pageID, GroupID) {
        $.ajax({
            url: "/Blog/GetNews?PageID=" + pageID,
            type: "Get",
            data: { PageID: pageID }
        }).done(function (result) {
            $("#p_0").html(result);
        });


    }



</script>
<script>
    function SearchsBlogs() {
        var q = $('#BlogSearchs').val();
        $.ajax({
            url: "/Blog/SearchBlogs?q=" + q,
            type: "Get",
            data: { q: q }
        }).done(function (result) {
            $("#Searched").html(result);
        });


    }
</script>
<script>
    function SearchBlogs() {
        var q = $('#BlogSearch').val();
        $.ajax({
            url: "/Blog/SearchBlogs?q="+q,
            type: "Get",
            data: { q:q }
        }).done(function (result) {
            $("#Searched").html(result);
        });


    }
</script>
<script>
    function GetBlogs(pageID,GroupID) {
        $.ajax({
            url: "/Blog/GetBlogs?GroupID=" + GroupID+"&PageID="+pageID,
            type: "Get",
            data: { GroupID: GroupID, PageID: pageID }
        }).done(function (result) {
            $("#p_"+GroupID).html(result);
        });


    }



</script>