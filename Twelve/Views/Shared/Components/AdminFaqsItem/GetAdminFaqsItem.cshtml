@model ViewModels.AdminFaqsPageDataViewModel
@if (Model.Faqs.Any())
{
    <div class="card-body table-responsive p-0">
        <table class="table table-bordered table-hover">
            <tbody>
                <tr>
                    <th>سوال</th>
                    <th>پاسخ</th>
                    <th>دسته بندی</th>
                    <th>*</th>
                </tr>
                @foreach (var item in Model.Faqs)
                {
                    <tr>
                        <td>@item.Question</td>
                        <td>@item.Answer</td>
                        <td>
                            @item.GroupName
                        </td>
                        <td>
                            <a href="/Admin/Faq/Update/@item.FaqID" class="btn btn-outline-warning rounded mx-1" title="ویرایش">
                                <span class="fa fa-edit"></span>
                            </a>
                            <a href="/Admin/Faq/Delete/@item.FaqID" class="btn btn-outline-danger rounded mx-1" title="حذف">
                                <span class="fa fa-trash"></span>
                            </a>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
    <div class="card-footer clearfix">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination pagination-sm m-0 justify-content-center ">
                @if (Model.Pagination.PageID == 1)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetFaqs(@(Model.Pagination.PageID - 1))">«</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetFaqs(@(Model.Pagination.PageID - 1))">«</a></li>

                }
                @foreach (var item in Model.Pagination.PageNumbers)
                {
                    if (item == Model.Pagination.PageID)
                    {
                        <li class="page-item active"><a class="page-link" onclick="GetFaqs(@(item))">@item</a></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" onclick="GetFaqs(@(item))">@item</a></li>
                    }
                }

                @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetFaqs(@(Model.Pagination.PageID + 1))">»</a></li>

                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetFaqs(@(Model.Pagination.PageID + 1))">»</a></li>

                }
            </ul>


        }
    </div>
}
