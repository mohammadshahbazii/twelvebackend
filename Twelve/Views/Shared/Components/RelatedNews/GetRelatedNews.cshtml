@model List<ViewModels.BlogItemViewModel>
@if (Model.Any())
{
    <div class="bg-silver p-5 position-relative">
        <!-- Article Content -->
        <div class="container">
            <!--Blog News-->
            <div data-aos="fade-up" data-aos-duration="1800" class="mb-5">
                <div class="row">
                    <div class="col-lg-12 col-md-12 pt-5">
                        <div class="row">
                            <div class="col-lg-6 col-md-12">
                                <h2 class="text-darkblue fw-bold d-inline-block">
                                    اخبار مرتبط
                                </h2>
                                <p class="text-green2 d-inline-block fw-bold mx-4">
                                    این بخش توضیحات کمی درباره عنوان
                                </p>
                            </div>
                            <div class="col-lg-6 col-md-12">
                                <div class="row">
                                    <div class="col-lg-8 col-md-12"></div>
                                    <div class="col-lg-4 col-md-12">
                                        <a href="/Blog" class="text-darkblue">
                                            مشاهده تمام پست ها<span class="fa fa-angle-left mx-2"></span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            @foreach (var item in Model)
                            {
                                <div class="col-lg-4 col-md-12 my-4">
                                    <a href="/PostNews/@item.BlogID" class="text-darkblue">
                                        <img src="/Images/Blogs/@item.ImageName"
                                             class="w-100 radius-20"
                                             alt="title" />
                                        <p class="text-darkblue mt-4 lh-lg">
                                            @item.Title
                                        </p>
                                    </a>
                                    <p class="text-darkblue fw-bold">
                                        <span class="fa fa-clock-o"></span>
                                        @item.CreateDate | @item.Source
                                    </p>
                                </div>

                            }
                        </div>
                    </div>
                </div>
            </div>
            <br />
            <!--Blog News-->
        </div>
        <!-- Article Content -->
    </div>
}