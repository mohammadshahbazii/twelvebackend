@model List<ViewModels.IndexSliderItemViewModel>
@if (Model.Any())
{
    <div class="d-none d-lg-block d-xl-block d-xxl-block">
        <div id="ContactCarousel"
             class="carousel slide mt-5"
             data-ride="carousel"
             data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active" data-bs-interval="4000">
                    <div class="row">
                        @for (var i = 0; i < (Model.Count / 3); i++)
                        {
                            <div class="col-lg-4 col-md-12">
                                <a href="@Model[i].Link">
                                    <img src="/Images/Sliders/@Model[i].ImageName"
                                         alt="@Model[0].Title"
                                         class="w-h-100" />
                                </a>
                            </div>

                        }
                    </div>
                </div>
                <div class="carousel-item" data-bs-interval="4000">
                    <div class="row">
                        @for (int i = (Model.Count / 3); i < ((Model.Count*2) /3); i++)
                        {
                            <div class="col-lg-4 col-md-12">
                                <a href="@Model[i].Link">
                                    <img src="/Images/Sliders/@Model[i].ImageName"
                                         alt="@Model[0].Title"
                                         class="w-h-100" />
                                </a>
                            </div>

                        }
                    </div>
                </div>
                <div class="carousel-item" data-bs-interval="4000">
                    <div class="row">
                        @for (int i = ((Model.Count * 2) / 3); i < (Model.Count); i++)
                        {
                            <div class="col-lg-4 col-md-12">
                                <a href="@Model[i].Link">
                                    <img src="/Images/Sliders/@Model[i].ImageName"
                                         alt="@Model[0].Title"
                                         class="w-h-100" />
                                </a>
                            </div>

                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="d-lg-none d-xl-none d-xxl-none d-md-block d-sm-block">
        <div id="ContactCarousel-mobile"
             class="carousel slide mt-5"
             data-ride="carousel"
             data-bs-ride="carousel">
            <div class="carousel-inner">
                @foreach (var item in Model)
                {
                    if (item == Model[0])
                    {
                        <div class="carousel-item active" data-bs-interval="4000">
                            <a href="@item.Link">
                                <img src="/Images/Sliders/@item.ImageName"
                                     alt="@item.Title"
                                     class="w-h-100" />
                            </a>
                        </div>

                    }
                    else
                    {
                        <div class="carousel-item" data-bs-interval="4000">
                            <a href="@item.Link">
                                <img src="/Images/Sliders/@item.ImageName"
                                     alt="@item.Title"
                                     class="w-h-100" />
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}