@model ViewModels.OrdersPageDataViewModel
@if (Model.Orders.Any())
{
    <div class="card-body table-responsive p-0">
        <table class="table table-bordered table-hover">
            <tbody>
                <tr>
                    <th>نتیجه تراکنش</th>
                    <th>مقدار تراکنش</th>
                    <th>تاریخ</th>
                </tr>
                @foreach (var item in Model.Orders)
                {
                    <tr>
                        @if (item.IsFinally)
                        {
                            <td>
                                <span class="badge bg-success">موفق</span>
                            </td>

                        }
                        else
                        {
                            <td>
                                <span class="badge bg-danger">ناموفق</span>

                            </td>
                        }
                        <td>
                            @item.Amount ریال
                        </td>
                        <td>@item.CreateDate</td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
    <div class="card-footer clearfix">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination pagination-sm m-0 justify-content-center ">
                @if (Model.Pagination.PageID == 1)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetOrders(@(Model.Pagination.PageID - 1))">«</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetOrders(@(Model.Pagination.PageID - 1))">«</a></li>

                }
                @foreach (var item in Model.Pagination.PageNumbers)
                {
                    if (item == Model.Pagination.PageID)
                    {
                        <li class="page-item active"><a class="page-link" onclick="GetOrders(@(item))">@item</a></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" onclick="GetOrders(@(item))">@item</a></li>
                    }
                }

                @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetOrders(@(Model.Pagination.PageID + 1))">»</a></li>

                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetOrders(@(Model.Pagination.PageID + 1))">»</a></li>

                }
            </ul>


        }
    </div>
}