@model ViewModels.AdminFeaturesPageDataViewModel
@if (Model.Features.Any())
{
    <div class="card-body table-responsive p-0">
        <table class="table table-bordered table-hover">
            <tbody>
                <tr>
                    <th>عنوان</th>
                    <th>*</th>
                </tr>
                @foreach (var item in Model.Features)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>
                            <a href="/Admin/IntroduceSliders/ShowItems/@item.FeatureID" class="btn btn-outline-info rounded mx-1" title="نمایش آیتم ها">
                                <span class="fa fa-list"></span>
                            </a>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
    <div class="card-footer clearfix">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination pagination-sm m-0 justify-content-center ">
                @if (Model.Pagination.PageID == 1)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID - 1))">«</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID - 1))">«</a></li>

                }
                @foreach (var item in Model.Pagination.PageNumbers)
                {
                    if (item == Model.Pagination.PageID)
                    {
                        <li class="page-item active"><a class="page-link" onclick="GetFeatures(@(item))">@item</a></li>
                    }
                    else
                    {
                        <li class="page-item"><a class="page-link" onclick="GetFeatures(@(item))">@item</a></li>
                    }
                }

                @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                {
                    <li class="page-item disabled"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID + 1))">»</a></li>

                }
                else
                {
                    <li class="page-item"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID + 1))">»</a></li>

                }
            </ul>


        }
    </div>
}