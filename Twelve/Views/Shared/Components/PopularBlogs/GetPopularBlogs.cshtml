@model List<ViewModels.IndexSliderItemViewModel>
<div class="my-4">
    <div id="BlogSingleSlider"
         class="carousel slide"
         data-bs-ride="true">
        <div class="carousel-indicatorsBlog carousel-indicators">
            <button type="button"
                    data-bs-target="#BlogSingleSlider"
                    data-bs-slide-to="0"
                    class="active"
                    aria-current="true"
                    aria-label="Slide 1"></button>
            <button type="button"
                    data-bs-target="#BlogSingleSlider"
                    data-bs-slide-to="1"
                    aria-label="Slide 2"></button>
        </div>
        <div class="carousel-inner">
            @foreach (var item in Model)
            {
                @if (item == Model[0])
                {
                    <div class="carousel-item active">
                        <img src="/Images/Blogs/@item.ImageName"
                             class="d-block w-100 radius-20"
                             alt="دوازده" />
                        <h5 class="text-darkblue py-3 text-justify fw-bold">
                            @item.Title
                        </h5>
                        <div class="carousel-caption text-end mb-20">
                            <a href="/PostBlogs/@item.SliderID" class="single-side-big-img">
                                <img src="/Assest/img/SVG/Main/blog-link-round.svg"
                                     alt="لینک به صفحه خبر"
                                     width="60px"
                                     class="single-page-carousel-link" />
                            </a>
                        </div>
                    </div>

                }
                else
                {
                    <div class="carousel-item ">
                        <img src="/Images/Blogs/@item.ImageName"
                             class="d-block w-100 radius-20"
                             alt="دوازده" />
                        <h5 class="text-darkblue py-3 text-justify fw-bold">
                            @item.Title
                        </h5>
                        <div class="carousel-caption text-end mb-20">
                            <a href="/PostBlogs/@item.SliderID" class="single-side-big-img">
                                <img src="/Assest/img/SVG/Main/blog-link-round.svg"
                                     alt="لینک به صفحه خبر"
                                     width="60px"
                                     class="single-page-carousel-link" />
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
