@model ViewModels.AdminFeaturesPageDataViewModel
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-lg-8 col-md-12">
                                <h3 class="card-title">
                                    لیست ویژگی های نرم افزار
                                </h3>
                            </div>
                            <div class="col-lg-4 col-md-12">
                                <div class="card-tools">
                                    <div class="input-group input-group-sm" style="width: 100%;">
                                        <input type="text" id="BlogSearch" name="BlogSearch" class="form-control float-right" placeholder="جستجو">

                                        <div class="input-group-append">
                                            <a onclick="GetFeatures($('#BlogSearch').val())" class="btn btn-default"><i class="fa fa-search"></i></a>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        

                    </div>
                    <!-- /.card-header -->
                    <div id="FeatureTable">
                        @if (Model.Features.Any())
                        {
                            <div class="card-body table-responsive p-0">
                                <table class="table table-bordered table-hover">
                                    <tbody>
                                        <tr>
                                            <th>عنوان</th>
                                            <th>*</th>
                                        </tr>
                                        @foreach (var item in Model.Features)
                                        {
                                            <tr>
                                                <td>@item.Title</td>
                                                <td>
                                                    <a href="/Admin/IntroduceSliders/ShowItems/@item.FeatureID" class="btn btn-outline-info rounded mx-1" title="نمایش آیتم ها">
                                                        <span class="fa fa-list"></span>
                                                    </a>
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                            <div class="card-footer clearfix">
                                @if (Model.PageCount > 1)
                                {
                                    <ul class="pagination pagination-sm m-0 justify-content-center ">
                                        @if (Model.Pagination.PageID == 1)
                                        {
                                            <li class="page-item disabled"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID - 1))">«</a></li>
                                        }
                                        else
                                        {
                                            <li class="page-item"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID - 1))">«</a></li>

                                        }
                                        @foreach (var item in Model.Pagination.PageNumbers)
                                        {
                                            if (item == Model.Pagination.PageID)
                                            {
                                                <li class="page-item active"><a class="page-link" onclick="GetFeatures(@(item))">@item</a></li>
                                            }
                                            else
                                            {
                                                <li class="page-item"><a class="page-link" onclick="GetFeatures(@(item))">@item</a></li>
                                            }
                                        }

                                        @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                                        {
                                            <li class="page-item disabled"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID + 1))">»</a></li>

                                        }
                                        else
                                        {
                                            <li class="page-item"><a class="page-link" onclick="GetFeatures(@(Model.Pagination.PageID + 1))">»</a></li>

                                        }
                                    </ul>


                                }
                            </div>
                        }
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>
<script>
    function GetFeatures(pageID) {
        var q = $('#BlogSearch').val();
        $.ajax({
            url: "/Admin/IntroduceSliders/GetFeatures?q=" + q + "&PageID=" + pageID,
            type: "Get",
            data: { q: q, PageID: pageID }
        }).done(function (result) {
            $("#FeatureTable").html(result);
        });


    }



</script>