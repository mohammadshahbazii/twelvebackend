@model List<DataLayer.IntroduceSlider>
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            لیست آیتم های اسلایدر معرفی نرم افزار
                            <a href="/Admin/IntroduceSliders/Create/@ViewBag.FeatureID" class="btn btn-outline-success mx-2">افزودن آیتم</a>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <div id="FeatureTable">
                        @if (Model.Any())
                        {
                            <div class="card-body table-responsive p-0">
                                <table class="table table-bordered table-hover">
                                    <tbody>
                                        <tr>
                                            <th>تصویر</th>
                                            <th>*</th>
                                        </tr>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td><img src="/Images/Sliders/@item.ImageName" width="110" height="180"/></td>
                                                <td>
                                                    <a href="/Admin/IntroduceSliders/Update/@item.IntroduceSliderId" class="btn btn-outline-warning rounded mx-1" title="ویرایش آیتم ">
                                                        <span class="fa fa-edit"></span>
                                                    </a>
                                                    <a href="/Admin/IntroduceSliders/Delete/@item.IntroduceSliderId" class="btn btn-outline-danger rounded mx-1" title="حذف آیتم ">
                                                        <span class="fa fa-trash"></span>
                                                    </a>
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="p-5 text-center">موردی یافت نشد</p>
                        }
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>