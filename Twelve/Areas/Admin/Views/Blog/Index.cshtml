@model ViewModels.AdminBlogPageDataViewModel

<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            لیست اخبار
                            <a href="/Admin/Blog/Create" class="btn btn-outline-success mx-3">افزودن خبر</a>
                        </h3>

                        <div class="card-tools">
                            <div class="input-group input-group-sm" style="width: 150px;">
                                <input type="text" id="BlogSearch" name="BlogSearch" class="form-control float-right" placeholder="جستجو">

                                <div class="input-group-append">
                                    <a onclick="GetBlogs($('#BlogSearch').val())" class="btn btn-default"><i class="fa fa-search"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-header -->
                    <div id="BlogTable">
                        @if (Model.Posts.Any())
                        {
                            <div class="card-body table-responsive p-0">
                                <table class="table table-bordered table-hover">
                                    <tbody>
                                        <tr>
                                            <th>عنوان</th>
                                            <th>دسته بندی</th>
                                            <th>تاریخ انتشار</th>
                                            <th>بازدید</th>
                                            <th>*</th>
                                        </tr>
                                        @foreach (var item in Model.Posts)
                                        {
                                            <tr>
                                                <td>@item.Title</td>
                                                <td>
                                                    @item.GroupName
                                                </td>
                                                <td>@item.CreateDate</td>
                                                <td>@item.View</td>
                                                <td>
                                                    <a href="/Admin/Blog/RelatedPosts/@item.BlogID" class="btn btn-outline-info rounded mx-1" title="مقالات مرتبط">
                                                        <span class="fa fa-list"></span>
                                                    </a>
                                                    <a href="/Admin/Blog/Update/@item.BlogID" class="btn btn-outline-warning rounded mx-1" title="ویرایش">
                                                        <span class="fa fa-edit"></span>
                                                    </a>
                                                    <a href="/Admin/Blog/Delete/@item.BlogID" class="btn btn-outline-danger rounded mx-1" title="حذف">
                                                        <span class="fa fa-trash"></span>
                                                    </a>
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                            <div class="card-footer clearfix">
                                @if (Model.PageCount > 1)
                                {
                                    <ul class="pagination pagination-sm m-0 justify-content-center ">
                                        @if (Model.Pagination.PageID == 1)
                                        {
                                            <li class="page-item disabled"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID - 1))">«</a></li>
                                        }
                                        else
                                        {
                                            <li class="page-item"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID - 1))">«</a></li>

                                        }
                                        @foreach (var item in Model.Pagination.PageNumbers)
                                        {
                                            if (item == Model.Pagination.PageID)
                                            {
                                                <li class="page-item active"><a class="page-link" onclick="GetBlogs(@(item))">@item</a></li>
                                            }
                                            else
                                            {
                                                <li class="page-item"><a class="page-link" onclick="GetBlogs(@(item))">@item</a></li>
                                            }
                                        }

                                        @if (Model.Pagination.PageID >= Model.Pagination.PageCount)
                                        {
                                            <li class="page-item disabled"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID + 1))">»</a></li>

                                        }
                                        else
                                        {
                                            <li class="page-item"><a class="page-link" onclick="GetBlogs(@(Model.Pagination.PageID + 1))">»</a></li>

                                        }
                                    </ul>


                                }
                            </div>
                        }
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>
<script>
    function GetBlogs(pageID) {
        var q = $('#BlogSearch').val();
        $.ajax({
            url: "/Admin/Blog/GetBlogPosts?q=" + q + "&PageID=" + pageID,
            type: "Get",
            data: { q: q, PageID: pageID }
        }).done(function (result) {
            $("#BlogTable").html(result);
        });


    }

</script>