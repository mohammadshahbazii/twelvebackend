@model DataLayer.AboutUsArticle
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title">
                            حذف مقاله
                            <span class="text-dark mx-2">@ViewBag.Message</span>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- form start -->
                    <form role="form" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="AboutUsArticleId" id="AboutUsArticleId" value="@Model.AboutUsArticleId" />
                        <input type="hidden" name="ImageName" id="ImageName" value="@Model.ImageName" />
                        <input type="hidden" name="Title" id="Title" value="@Model.Title" />
                        <input type="hidden" name="Description" id="Description" value="@Model.Description" />
                        <input type="hidden" name="SubTitle" id="SubTitle" value="@Model.SubTitle" />
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Title">عنوان</label>
                                <p>@Model.Title</p>
                            </div>
                            <div class="form-group">
                                <label for="SubTitle">زیر عنوان</label>
                                <p>@Model.SubTitle</p>
                            </div>
                            <div class="form-group">
                                <label for="Description">توضیح تکمیلی</label>
                                <p>@Model.Description</p>
                            </div>
                            <div class="form-group ">
                                <div class="text-center">
                                    <img id="imagePreview" class="thumbnail my-5 w-50 mx-auto" src="~/Images/Site/@Model.ImageName" />
                                </div>
                            </div>
                        </div>
                        <!-- /.card-body -->

                        <div class="card-footer">
                            <button type="submit" class="btn btn-danger">حذف</button>
                            <a href="/Admin/AboutArticles" class="btn btn-info float-left">بازگشت به لیست</a>
                        </div>
                    </form>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>
<script>
    imageProduct.onchange = evt => {
        const [file] = imageProduct.files
        if (file) {
            imagePreview.src = URL.createObjectURL(file)
        }
    }
</script>