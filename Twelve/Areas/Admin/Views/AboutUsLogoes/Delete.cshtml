@model DataLayer.AboutUsLogo
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title">
                            حذف لوگو
                            <span class="text-dark mx-2">@ViewBag.Message</span>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- form start -->
                    <form role="form" method="post" enctype="multipart/form-data">
                        @Html.HiddenFor(m=> m.ImageName)
                        @Html.HiddenFor(m=> m.AboutUsLogoId)
                        @Html.HiddenFor(m=> m.IsMain)
                        <div class="card-body">

                            <div class="form-group ">
                                <div class="text-center">
                                    <img id="imagePreview" class="thumbnail my-5" src="~/Images/Site/@Model.ImageName" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="IsMain">فضای بیشتر</label>
                                @if (Model.IsMain)
                                {
                                    <p>بله</p>
                                }
                                else
                                {
                                    <p>خیر</p>
                                }
                            </div>
                        </div>
                        <!-- /.card-body -->

                        <div class="card-footer">
                            <button type="submit" class="btn btn-danger">حذف</button>
                            <a href="/Admin/AboutUsLogoes" class="btn btn-info float-left">بازگشت به لیست</a>
                        </div>
                    </form>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>
