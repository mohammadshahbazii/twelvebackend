@model DataLayer.Advertisement
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title">
                            حذف اطلاعات تماس
                            <span class="text-dark mx-2">@ViewBag.Message</span>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- form start -->
                    <form role="form" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="AdvertisementId" id="AdvertisementId" value="@Model.AdvertisementId" />
                        <input type="hidden" name="ImageName" id="ImageName" value="@Model.ImageName" />
                        <input type="hidden" name="Title" id="Title" value="@Model.Title" />
                        <input type="hidden" name="Link" id="Link" value="@Model.Link" />
                        <div class="card-body">
                            <div class="form-group">
                                <label for="Link">لینک</label>
                                <p>@Model.Link</p>

                            </div>
                            <div class="form-group ">
                                <div class="text-center">
                                    <img id="imagePreview" class="thumbnail my-5 w-50 mx-auto" src="~/Images/Ads/@Model.ImageName" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="IsBanner">بنر صفحه وبلاگ</label>
                                @if (Model.IsBanner)
                                {
                                    <p>بله</p>

                                }
                                else
                                {
                                    <p>خیر</p>

                                }
                            </div>
                        </div>
                        <!-- /.card-body -->

                        <div class="card-footer">
                            <button type="submit" class="btn btn-danger">حذف</button>
                            <a href="/Admin/Advertisements" class="btn btn-info float-left">بازگشت به لیست</a>
                        </div>
                    </form>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>