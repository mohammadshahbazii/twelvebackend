    <!-- Template ckeditor -->
    <script>
        $(document).ready(function () {
            function checkWindowSize() {
                var width = $(window).width();
                if (width < 992) {  // Bootstrap Medium screen sizes (768px to 991px)
                    $('#AdminBody').removeClass('sidebar-open');
                }
            }

            // Check window size on load
            checkWindowSize();

            // Optionally, check window size on resize
            $(window).resize(function () {
                checkWindowSize();
            });
        });

    </script>
