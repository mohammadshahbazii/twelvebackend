@model DataLayer.FaqGroup
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title">
                            حذف دسته بندی
                            <span class="text-dark mx-2">@ViewBag.Message</span>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- form start -->
                    <form role="form" method="post">
                        @Html.HiddenFor(m=> m.FaqGroupId)
                        @Html.HiddenFor(m=> m.ParentId)
                        @Html.HiddenFor(m=> m.GroupName)
                        <div class="card-body">
                            <div class="form-group">
                                <label for="GroupName">عنوان</label>
                                <p>@Model.GroupName</p>
                            </div>
                        </div>
                        <!-- /.card-body -->

                        <div class="card-footer">
                            <button type="submit" class="btn btn-danger">حذف</button>
                            <a href="/Admin/FaqsGroup" class="btn btn-info float-left">بازگشت به لیست</a>
                        </div>
                    </form>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>