@model DataLayer.AboutUsSight
<div class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title">
                            حذف چشم انداز
                            <span class="text-dark mx-2">@ViewBag.Message</span>
                        </h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- form start -->
                    <form role="form" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="AboutUsSightId" id="AboutUsSightId" value="@Model.AboutUsSightId" />
                        <input type="hidden" name="ImageName" id="ImageName" value="@Model.ImageName" />
                        <input type="hidden" name="SightTitle" id="SightTitle" value="@Model.SightTitle" />
                        <input type="hidden" name="SightDescription" id="SightDescription" value="@Model.SightDescription" />
                        <div class="card-body">
                            <div class="form-group">
                                <label for="SightTitle">عنوان</label>
                                <p>@Model.SightTitle</p>
                            </div>
                            <div class="form-group">
                                <label for="SightDescription">توضیح تکمیلی</label>
                                <p>@Model.SightDescription</p>
                            </div>
                            <div class="form-group ">
                                <div class="text-center">
                                    <img id="imagePreview" class="thumbnail my-5" src="~/Images/Site/@Model.ImageName" />
                                </div>
                            </div>
                        </div>
                        <!-- /.card-body -->

                        <div class="card-footer">
                            <button type="submit" class="btn btn-danger">حذف</button>
                            <a href="/Admin/AboutUsSight" class="btn btn-info float-left">بازگشت به لیست</a>
                        </div>
                    </form>
                </div>
                <!-- /.card -->
            </div>
        </div>
    </div><!-- /.container-fluid -->
</div>
<script>
    imageProduct.onchange = evt => {
        const [file] = imageProduct.files
        if (file) {
            imagePreview.src = URL.createObjectURL(file)
        }
    }
</script>